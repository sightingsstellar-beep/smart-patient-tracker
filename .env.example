# Glide Patient Tracker — Environment Variables
# Copy this file to .env and fill in your values

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# OpenAI API Key (gpt-4o-mini for NLP parsing)
OPENAI_API_KEY=

# Authorized Telegram user IDs (comma-separated)
# To find your Telegram ID: message @userinfobot
AUTHORIZED_USER_IDS=8573495743

# Dashboard password (required — protects the web UI)
DASHBOARD_PASSWORD=

# Alexa Skill ID — copy from developer.amazon.com after creating the skill
# Requests from other skill IDs will be rejected (leave blank during initial setup)
ALEXA_SKILL_ID=

# Session secret — use a long random string (e.g. openssl rand -hex 32)
SESSION_SECRET=

# Optional API key for programmatic access (for example /api/backup via x-api-key)
API_KEY=

# Optional, local-only auth spike. Keep disabled in production until Clerk is selected.
CLERK_SPIKE_ENABLED=false
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional token for the kiosk display routes (/display and /api/display-data)
DISPLAY_TOKEN=

# Server port (Railway sets this automatically)
PORT=3000

# Timezone for fluid day calculation and report times
# Must be a valid IANA timezone name
TZ=America/New_York

# Optional: path to store SQLite database (default: ./data/elina.db)
# On Railway, use /data if you've set up a persistent volume
# DATA_DIR=/data
