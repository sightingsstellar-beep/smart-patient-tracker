# Glide Bedside — Environment Variables
# Copy this file to .env and fill in your values

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# OpenAI API Key (gpt-4o-mini for NLP parsing)
OPENAI_API_KEY=

# Authorized Telegram user IDs (comma-separated)
# To find your Telegram ID: message @userinfobot
AUTHORIZED_USER_IDS=8573495743

# Legacy dashboard password (used only when CLERK_AUTH_ENABLED=false)
DASHBOARD_PASSWORD=

# Alexa Skill ID — copy from developer.amazon.com after creating the skill
# Requests from other skill IDs will be rejected (leave blank during initial setup)
ALEXA_SKILL_ID=

# Session secret — use a long random string (e.g. openssl rand -hex 32)
SESSION_SECRET=

# Optional API key for programmatic access (for example /api/backup via x-api-key)
API_KEY=

# Clerk browser auth. Enable before Alexa certification reviewer testing.
CLERK_AUTH_ENABLED=false
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Temporary migration guard: comma-separated emails allowed to auto-attach to the default patient tenant.
# Keep restricted to known caregivers until all legacy data has explicit memberships.
CLERK_DEFAULT_TENANT_ALLOWED_EMAILS=

# Caregiver invitation email delivery. Keep disabled until SMTP credentials are set in secret storage/Railway.
INVITE_EMAIL_ENABLED=false
APP_PUBLIC_URL=https://bedside.glidechart.com
MAIL_FROM="Glide Bedside <support@glidechart.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Optional, local-only auth spike. Keep disabled in production.
CLERK_SPIKE_ENABLED=false

# Optional token for the kiosk display routes (/display and /api/display-data)
DISPLAY_TOKEN=

# Server port (Railway sets this automatically)
PORT=3000

# Timezone for fluid day calculation and report times
# Must be a valid IANA timezone name
TZ=America/New_York

# Optional: path to store SQLite database (default: ./data/elina.db)
# On Railway, use /data if you've set up a persistent volume
# DATA_DIR=/data
